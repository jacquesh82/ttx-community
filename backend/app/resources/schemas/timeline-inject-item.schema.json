{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ttx.local/schemas/timeline-inject-item.schema.json",
  "title": "Timeline Inject Item",
  "allOf": [
    {
      "$ref": "https://ttx.local/schemas/inject-bank-item.schema.json#/$defs/shared_fields"
    }
  ],
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "exercise_id": { "type": "integer", "minimum": 1 },
    "custom_id": { "type": "string", "maxLength": 100 },
    "title": { "type": "string", "minLength": 1, "maxLength": 255 },
    "type": {
      "type": "string",
      "enum": [
        "mail",
        "sms",
        "call",
        "socialnet",
        "tv",
        "doc",
        "directory",
        "story",
        "system"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "mail",
        "sms",
        "call",
        "socialnet",
        "tv",
        "doc",
        "directory",
        "story"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "scheduled", "sent", "cancelled"]
    },
    "timeline_type": { "type": "string", "enum": ["business", "technical"] },
    "time_offset": { "type": ["integer", "null"], "minimum": 0 },
    "duration_min": { "type": "integer", "minimum": 1 },
    "phase_id": { "type": ["integer", "null"], "minimum": 1 },
    "description": { "type": ["string", "null"] },
    "data_format": {
      "type": "string",
      "enum": ["text", "audio", "video", "image"]
    },
    "content": { "type": "object" },
    "scheduled_at": { "type": ["string", "null"], "format": "date-time" },
    "is_surprise": { "type": "boolean" },
    "target_user_ids": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 }
    },
    "target_team_ids": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 }
    },
    "audiences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string", "enum": ["role", "team", "user", "tag"] },
          "value": { "type": ["string", "integer"] }
        },
        "required": ["kind", "value"]
      }
    },
    "category": { "type": "string", "maxLength": 100 },
    "summary": { "type": "string" },
    "source_url": { "type": "string", "maxLength": 500 },
    "payload": { "type": "object" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "title",
    "type",
    "status",
    "timeline_type",
    "duration_min",
    "data_format",
    "content"
  ]
}
